rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email in ['helpdesk@next-genius.com', 'mandhana.neeraj@gmail.com'];
    }

    match /applicants/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    match /tests/{uid} {
      allow create, read, update: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    match /colleges/{slug} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /broadcasts/{id} {
      allow read, write: if isAdmin();
    }

    // AI interview scorecards. Admin-only read; written solely by the
    // GitHub Action worker via the Admin SDK (which bypasses these rules).
    // Students must NOT be able to read their own evaluation.
    match /interviewEvals/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
